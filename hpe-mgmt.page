<style>
  /* Advanced-only blocks are hidden until the top-level switch turns them on.
     Matches the dynamix convention used by Syslinux / DockerSettings. */
  .advanced { display: none; }
</style>
<script>
  $(function () {
    if ($.cookie('hpe_mgmt_viewmode') === 'advanced') {
      $('.advanced').show();
    }
    $('.advancedview').switchButton({
      labels_placement: 'left',
      off_label: 'Basic view',
      on_label:  'Advanced view',
      checked:   $.cookie('hpe_mgmt_viewmode') === 'advanced'
    });
    $('.advancedview').change(function () {
      $('.advanced').toggle('slow');
      $.cookie('hpe_mgmt_viewmode',
        $('.advancedview').is(':checked') ? 'advanced' : 'basic',
        {expires: 3650});
    });

    /* Show only the bits relevant to the current stack — the amsd
       Tier 2 checkbox is Modern-only (Legacy already bundles hp-ams),
       and each repo-source block belongs to its own stack. */
    function hpeMgmtToggleStack() {
      var s = $('select[name=STACK]').val();
      $('.hpe-modern-only').toggle(s === 'modern');
      $('.hpe-legacy-only').toggle(s === 'legacy');
      $('.hpe-src-modern').toggle(s === 'modern');
      $('.hpe-src-legacy').toggle(s === 'legacy');
    }
    hpeMgmtToggleStack();
    $('select[name=STACK]').change(hpeMgmtToggleStack);
  });
</script>

