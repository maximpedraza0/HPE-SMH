<?PHP
/* HPE Management — unRAID settings page.
 * Config persists at /boot/config/plugins/hpe-mgmt/hpe-mgmt.cfg.
 * Save handler lives in include/settings.php.
 */

$plugin   = "hpe-mgmt";
$plugdir  = "/usr/local/emhttp/plugins/$plugin";
$cfg_path = "/boot/config/plugins/$plugin/$plugin.cfg";
require_once "$plugdir/include/cfg.php";
$defaults = hpe_mgmt_read_cfg("$plugdir/$plugin.cfg.default");
$current  = file_exists($cfg_path) ? hpe_mgmt_read_cfg($cfg_path) : $defaults;

$stack        = $current['STACK']           ?? 'modern';
$extras       = $current['EXTRAS']          ?? '';
$mcp_dist     = $current['MCP_DIST']        ?? 'CentOS';
$mcp_ver      = $current['MCP_VER']         ?? '8';
$spp_ver      = $current['SPP_LEGACY_VER']  ?? 'auto';
$install_amsd = $current['INSTALL_AMSD']    ?? '0';
$snmp_rev     = $current['ENABLE_SNMP_REV'] ?? '0';
$gpg          = $current['VERIFY_GPG']      ?? '1';

$extras_set = array_flip(preg_split('/\s+/', trim($extras)));

function chk($cond) { return $cond ? 'checked'  : ''; }
function sel($cond) { return $cond ? 'selected' : ''; }

/* Register plugin help strings into unRAID's $language map so we can
 * use the native :hpe_mgmt_xxx_help: syntax in the markdown body.  The
 * translate() call reached at eval time will find our entries and
 * emit a Markdown-rendered blockquote in-place — same pattern as
 * Settings/ManagementAccess and the other stock pages. */
/* Markdown blockquotes (each line starts with "> ") render into the
 * same blue-bordered <blockquote> that unRAID uses for its own
 * :foo_help: entries (see default-base.css ≈ line 1715). */
global $language;
$language['_hpe_mgmt_stack_help'] = <<<MD
> Which set of HPE management software to install and start.
>
> * **Modern** — CLI-only install (`ssacli` for Smart Array, `hponcfg` for iLO).
> * **Legacy SMH** — brings the System Management Homepage back: a web dashboard
>   on port **2381** that aggregates health, storage, firmware and SNMP data.
> * **Disabled** — stops everything the plugin controls but leaves the plugin
>   installed for later re-enable.
MD;

$language['_hpe_mgmt_amsd_help'] = <<<MD
> HPE **Agentless Management Service daemon**.  Pushes OS-side telemetry
> (CPU, memory, disks, NICs, PSU) into iLO over the PCIe management channel,
> so the iLO web UI and Integrated Management Log see a complete picture.
>
> Designed for Gen10 and newer; on Gen8 the iLO 4 firmware already gets what
> it needs from hp-ams.  Enabling this also installs the EL8 compat-libs
> bundle (~8 MB).
MD;

$language['_hpe_mgmt_extras_network_help'] = <<<MD
> **Fibre Channel / SAN panels** in SMH plus NIC-vendor utilities.
> Ethernet data already comes from `hp-snmp-agents` (installed with the
> legacy stack) via the `cmanicd` daemon.
>
> * **fibreutils** — Emulex / QLogic FC HBA utilities; feeds SMH's
>   Fibre Channel panel.
> * **hpe-emulex-smartsan-enablement-kit** — enables HPE Smart SAN
>   (auto-zoning + fabric health) for Emulex FC HBAs.
> * **hpe-qlogic-smartsan-enablement-kit** — same Smart SAN integration
>   for QLogic FC HBAs.
> * **mft** — Mellanox Firmware Tools (`flint`, `mlxfwreset`, `mst`
>   driver).  Only useful if you have Mellanox / NVIDIA ConnectX
>   adapters.  No SMH panel.  "Start at boot" loads the `mst` kernel
>   module so the CLI can talk to the cards.
> * **hp-tg3sd** — Broadcom tg3 NIC status daemon for NetXtreme BCM57xx
>   cards common on Gen8/Gen9.  Feeds NIC health into the CMA NIC
>   panel inside SMH.
MD;

$language['_hpe_mgmt_extras_storage_help'] = <<<MD
> **Storage panel** in SMH plus RAID / disk diagnostic CLIs.
>
> * **ssa** — Graphical RAID configuration for Smart Array controllers;
>   registers as the Storage panel inside the Legacy SMH web UI.
> * **ssaducli** — CLI that generates the Smart Storage diagnostic
>   bundle HPE support asks for when you open a storage case.
> * **storcli** — Broadcom/LSI MegaRAID CLI.  Only for non-HPE RAID
>   cards (SAS3416, SAS9361, etc.); Smart Array uses `ssacli`.
> * **hp-ocsbbd** — Smart Array cache battery monitoring daemon.
>   Pulls backup-battery health into CMA so SMH's Storage panel can
>   warn when the flash-backed write cache is running on a failing
>   or missing battery.
MD;

$language['_hpe_mgmt_asrd_help'] = <<<MD
> **Automatic Server Recovery** — hardware watchdog that reboots the
> server if the kernel panics or hangs for more than the configured
> timeout.  Uses `/dev/watchdog` from the `hpwdt` driver (iLO2/iLO3/iLO4)
> or the generic IPMI watchdog as a fallback.
>
> Comes bundled with `hp-health` (installed automatically by the Legacy
> stack).  **Off by default** — enabling this changes how the machine
> behaves under a crash (it reboots instead of staying down).  When
> on, a new Automatic Server Recovery panel appears inside SMH.
MD;

$language['_hpe_mgmt_extras_versioning_help'] = <<<MD
> **Version Control / firmware management**.  HPE's classic Version
> Control Agent was retired; its role is now split between these tools.
>
> * **sut** — Smart Update Tool (daemon); pulls firmware baselines down
>   from iLO / SPP and applies them.
> * **sum** — Smart Update Manager (UI-driven).  Interactive replacement
>   for the old VCA — inventory, plan and apply firmware updates.  No
>   SMH panel; runs its own front-end.
> * **ilorest** — iLO REDFISH client CLI (scriptable automation of
>   anything the iLO web UI exposes).
> * **hponcfg** — reconfigure iLO from the OS (IP, user, certs, reset).
>   Already bundled with the modern and legacy stacks.
MD;

$language['_hpe_mgmt_snmp_rev_help'] = <<<MD
> HPE CMA agents normally answer the proprietary `cma*` protocol on their
> own sockets.  The `_rev` variants are shims that forward the same data
> to a local Net-SNMP daemon (`snmpd`), so standard SNMP monitoring tools
> can read HPE OIDs.  Leave off unless you already run snmpd on the host.
MD;

$language['_hpe_mgmt_gpg_help'] = <<<MD
> End-to-end integrity check of every RPM.  The plugin downloads
> `repomd.xml` and its signature from each repo (HPE SDR + AlmaLinux),
> verifies with the pinned keys under `source/keys/`, then sha1/sha256-
> checks every package against the `primary.xml` manifest before
> `rpm2tgz`.  With it off only TLS protects the wire.  Keep on unless
> debugging a broken repo.
MD;

$language['_hpe_mgmt_advanced_help'] = <<<MD
> Exposes repository-source controls and other expert knobs.  Defaults
> are already tuned for every supported ProLiant generation — flip this
> on only if you need to pin a specific SPP drop or change the MCP
> distribution.
MD;

/* Service status via rc script — best effort.  Missing script means the
 * plugin has never been applied yet. */
$rc = "/etc/rc.d/rc.$plugin";
$status = is_executable($rc)
    ? trim(shell_exec("$rc status 2>&1"))
    : "(not yet applied — click Apply below)";

/* Collect every web UI the plugin has made available on this box. */
$web_links = [];
$host = $_SERVER['SERVER_NAME'] ?? 'your-unraid';

/* SMH — listens on :2381 when legacy stack is up. */
$smh_listening = trim(shell_exec(
    "ss -tln 2>/dev/null | awk '\$4 ~ /:2381\$/ {print \$4; exit}'"
));
if ($smh_listening !== '') {
    $web_links[] = [
        'label' => 'HPE System Management Homepage',
        'url'   => "https://{$host}:2381/",
        'note'  => 'aggregated hardware dashboard — login with root OS credentials',
    ];
    if (is_dir('/opt/smartstorageadmin')) {
        $web_links[] = [
            'label' => 'Smart Storage Administrator (RAID)',
            'url'   => "https://{$host}:2381/ssa/",
            'note'  => 'Smart Array controller configuration',
        ];
    }
}

/* iLO — query its IP via hponcfg if we have it + the kernel module. */
if (is_executable('/sbin/hponcfg') && is_dir('/dev/hpilo')) {
    $out = shell_exec("/sbin/hponcfg -w /tmp/ilo.xml 2>/dev/null && xmllint --xpath \"string(//IP_ADDRESS/@VALUE)\" /tmp/ilo.xml 2>/dev/null; rm -f /tmp/ilo.xml");
    $ilo_ip = trim($out);
    if ($ilo_ip !== '' && filter_var($ilo_ip, FILTER_VALIDATE_IP)) {
        $web_links[] = [
            'label' => 'iLO Management',
            'url'   => "https://{$ilo_ip}/",
            'note'  => 'out-of-band iLO firmware web UI',
        ];
    }
}

/* ---- Hardware status -------------------------------------------------
 * Modern stack has no web UI — everything is CLI.  Summarise here what
 * ssacli, hponcfg and lsmod would show on a root shell, so the user
 * gets a one-glance view of the hardware the plugin is managing.
 */
function hpe_mgmt_server_generation() {
    $name = trim(shell_exec('dmidecode -s system-product-name 2>/dev/null'));
    if ($name === '') return ['name'=>'', 'gen'=>'', 'spp'=>''];
    /* Match "Gen8", "Gen10", "Gen10 Plus", etc. */
    $gen = ''; $spp = '';
    if (preg_match('/Gen(\d+)(\s*Plus)?/i', $name, $m)) {
        $gen = 'Gen' . $m[1] . (!empty($m[2]) ? ' Plus' : '');
        $spp = [
            '8'  => '2020.09.0',  // last drop with ssa 4.x that detects P420 etc.
            '9'  => '2021.10.0',
            '10' => '2022.03.0',  // newest SPP with SMH
        ][$m[1]] ?? '2022.03.0';
    }
    return ['name' => $name, 'gen' => $gen, 'spp' => $spp];
}
$hwgen = hpe_mgmt_server_generation();

function hpe_mgmt_module_status() {
    if (trim(shell_exec("lsmod 2>/dev/null | awk '\$1==\"hpilo\"{print;exit}'")) !== '') {
        $vm = trim(shell_exec(
            "modinfo -F vermagic /lib/modules/\$(uname -r)/extra/hpilo.ko 2>/dev/null"
        ));
        $vm = $vm !== '' ? $vm : '(unknown)';
        return ['loaded' => true,  'detail' => "loaded — vermagic: {$vm}"];
    }
    if (is_readable("/lib/modules/" . trim(shell_exec('uname -r')) . "/extra/hpilo.ko")) {
        return ['loaded' => false, 'detail' => 'built but not loaded (modprobe hpilo)'];
    }
    return ['loaded' => false, 'detail' => 'not installed (external builder hasn\'t run)'];
}

function hpe_mgmt_ssacli_summary() {
    if (!is_executable('/usr/sbin/ssacli')) return null;
    return trim(shell_exec('/usr/sbin/ssacli controller all show 2>&1'));
}

function hpe_mgmt_hponcfg_summary() {
    if (!is_executable('/sbin/hponcfg')) return null;
    /* -g prints generic info; short and non-interactive. */
    $out = trim(shell_exec('/sbin/hponcfg -g 2>&1'));
    /* If the hpilo driver isn't loaded hponcfg emits a multi-line error; keep it short. */
    if (strpos($out, 'CPQCIDRV driver is not loaded') !== false) {
        return "(iLO driver not loaded — load hpilo.ko to query)";
    }
    return $out;
}

$module    = hpe_mgmt_module_status();
$ssacli    = hpe_mgmt_ssacli_summary();
$hponcfg   = hpe_mgmt_hponcfg_summary();
